PORT=5000
MONGODB_URI=mongodb+srv://youruser:yourpass@cluster.mongodb.net/upstream
JWT_SECRET=a_random_string_at_least_32_characters_long
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional — raises GitHub API rate limit from 60 to 5000 req/hr
# Get one at: https://github.com/settings/tokens (no special scopes needed)
GITHUB_API_TOKEN=optional_github_personal_access_token

# AI Issue Summarizer (Google AI Studio — Gemini 1.5 Flash, free)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
